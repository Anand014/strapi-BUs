{
  "kind": "collectionType",
  "collectionName": "tenants",
  "info": {
    "singularName": "tenant",
    "pluralName": "tenants",
    "displayName": "Tenant",
    "description": "Multi-tenant isolation (partners, internal teams, public portal)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "tenant_key": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "products": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product",
      "mappedBy": "tenant"
    },
    "content_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::content-item.content-item",
      "mappedBy": "tenant"
    },
    "navigation_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::navigation-item.navigation-item",
      "mappedBy": "tenant"
    },
    "categories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::content-category.content-category",
      "mappedBy": "tenant"
    }
  }
}
