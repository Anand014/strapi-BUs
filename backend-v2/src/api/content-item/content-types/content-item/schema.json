{
  "kind": "collectionType",
  "collectionName": "content_items",
  "info": {
    "singularName": "content-item",
    "pluralName": "content-items",
    "displayName": "Content Item",
    "description": "Main documentation pages (rich text, embedded images, Swagger/OpenAPI)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "summary": {
      "type": "text"
    },
    "content": {
      "type": "richtext",
      "required": true
    },
    "plantuml_source": {
      "type": "text",
      "required": false
    },
    "content_type": {
      "type": "enumeration",
      "enum": [
        "overview",
        "getting_started",
        "glossary",
        "api_use_case",
        "build_order_guide"
      ]
    },
    "source_path": {
      "type": "string"
    },
    "swagger": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::swagger.swagger"
    },
    "swagger_version": {
      "type": "string"
    },
    "operations": {
      "type": "json"
    },
    "example_id": {
      "type": "string"
    },
    "media": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "visibility": {
      "type": "enumeration",
      "required": true,
      "default": "public",
      "enum": [
        "public",
        "private"
      ]
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "tenant": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tenant.tenant",
      "inversedBy": "content_items"
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "content_items"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::content-category.content-category",
      "inversedBy": "content_items"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "content_items"
    },
    "current_version": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::version.version"
    },
    "versions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::version.version",
      "mappedBy": "content_item"
    },
    "metadata": {
      "type": "json"
    },
    "navigation_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::navigation-item.navigation-item",
      "mappedBy": "content_item"
    }
  }
}
