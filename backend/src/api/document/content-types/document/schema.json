    },
    "documentShares": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::document-share.document-share",
      "mappedBy": "document"
    },
    "documentAccesses": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::document-access.document-access",
      "mappedBy": "document"
    },
