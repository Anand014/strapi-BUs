{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "node",
    "target": "es2020",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "baseUrl": ".",
    "paths": {
      "@strapi/*": ["node_modules/@strapi/*"]
    }
  },
  "exclude": ["node_modules", ".tmp", "build", ".cache"]
}
